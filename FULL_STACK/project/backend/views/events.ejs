<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Browse and book amazing events" />
  <title>Events - Event Ticketing System</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="fade-in">
  <div class="app-container">
    <div class="main-content">
      <!-- Navbar -->
      <nav class="navbar">
        <div class="navbar-brand">EventSync</div>
        <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">☰</button>
        <div class="nav-actions" id="navMenu">
          <a class="nav-item" href="/events">📅 Events</a>
          <a class="nav-item" href="/dashboard">🏠 Dashboard</a>
          <a class="nav-item" href="/profile">👤 Profile</a>
          <a class="nav-item btn-cancel" href="/logout">🚪 Logout</a>
        </div>
        <button class="dark-toggle" title="Toggle dark mode">🌓</button>
      </nav>

      <main>
        <!-- Events Page Header -->
        <section class="events-page-header">
          <h1>🎪 Discover Events</h1>
          <p>Find and book tickets for amazing events happening near you</p>
          
          <!-- Search Bar -->
          <div class="search-wrapper" style="margin-top: 1.5rem;">
            <span class="search-icon">🔍</span>
            <input 
              type="text" 
              id="searchEvent" 
              class="search-input"
              placeholder="Search events by name, category..." 
              data-search 
            />
          </div>
        </section>

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="info" style="margin-bottom: 1.5rem;">
            <strong>ℹ️ Info:</strong> <%= message %>
          </div>
        <% } %>

        <!-- Create Event Section (Admin Only) -->
        <% if (user && user.role === "admin") { %>
          <section class="create-event-section card">
            <div class="card-header">
              <h2 style="margin: 0; display: flex; align-items: center; gap: 0.75rem;">
                <span>✨</span> Create New Event
              </h2>
            </div>
            <div class="card-body">
              <form action="/events/create" method="POST" class="event-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="title">Event Title</label>
                    <input type="text" id="title" name="title" placeholder="e.g., Tech Conference 2024" required />
                  </div>
                  <div class="form-group">
                    <label for="category">Category</label>
                    <input type="text" id="category" name="category" placeholder="e.g., Technology, Music" required />
                  </div>
                </div>
                <div class="form-group">
                  <label for="description">Description</label>
                  <textarea id="description" name="description" placeholder="Describe your event..."></textarea>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="event_date">Event Date & Time</label>
                    <input type="datetime-local" id="event_date" name="event_date" required />
                  </div>
                  <div class="form-group">
                    <label for="total_seats">Total Seats</label>
                    <input type="number" id="total_seats" name="total_seats" min="1" placeholder="e.g., 100" required />
                  </div>
                </div>
                <button type="submit" class="btn-submit">
                  <span>➕ Create Event</span>
                </button>
              </form>
            </div>
          </section>
        <% } %>

        <!-- Events Grid -->
        <section class="events-section">
          <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--text-color);">
            🎟️ Available Events
          </h2>
          <div class="events-grid" id="eventsGrid">
            <% events.forEach((event) => { %>
              <div class="event-full-card event-item" data-title="<%= event.title.toLowerCase() %>">
                <div class="event-card-header">
                  <h3><%= event.title %></h3>
                  <div class="badges">
                    <span class="category-badge"><%= event.category %></span>
                  </div>
                </div>
                <div class="event-card-body">
                  <p><strong>📝 Description:</strong> <%= event.description || "No description available" %></p>
                  <p><strong>📅 Date:</strong> <%= new Date(event.event_date).toLocaleDateString() %> at <%= new Date(event.event_date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                  <p><strong>👤 Organizer:</strong> <%= event.creator_name %></p>
                  <p><strong>🎫 Available Seats:</strong> <span class="seats" data-event-id="<%= event.id %>"><%= event.available_seats %></span> / <%= event.total_seats %></p>
                  <p class="countdown" data-date="<%= event.event_date %>">⏱️ Starts in --</p>
                </div>
                <div class="event-card-footer">
                  <% if (!user || user.role !== "admin") { %>
                    <form class="book-form" data-event-id="<%= event.id %>">
                      <input type="number" name="seat_count" min="1" max="5" value="1" required placeholder="Seats" />
                      <button type="submit" class="btn-submit">🎫 Book Now</button>
                    </form>
                  <% } else { %>
                    <a href="/events/delete/<%= event.id %>" class="btn-action btn-delete" onclick="return confirm('Delete this event?')">🗑️ Delete</a>
                    <form action="/events/update/<%= event.id %>" method="POST" class="event-form" style="display: flex; gap: 0.5rem;">
                      <input type="text" name="title" value="<%= event.title %>" required style="flex: 1;" />
                      <button type="submit" class="btn-action btn-edit">✏️ Update</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>

          <% if (events.length === 0) { %>
            <div class="card" style="text-align: center; padding: 3rem 2rem;">
              <p style="font-size: 3rem; margin: 0;">🎪</p>
              <h3 style="margin: 1rem 0 0.5rem 0; color: var(--text-color);">No Events Found</h3>
              <p style="color: var(--text-secondary); margin: 0;">Check back soon for upcoming events!</p>
            </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="alertBox" class="toast"></div>
  
  <!-- Loading Spinner -->
  <div id="loadingBox" class="spinner" style="display:none;"></div>

  <script>
    window.__USER_ROLE__ = "<%= user && user.role ? user.role : 'user' %>";
  </script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/app.js"></script>
  <script src="/realtime.js"></script>
</body>
</html>
